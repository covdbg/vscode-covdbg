# Default: auto-detect text files and normalize to LF in the repository.
* text=auto eol=lf

# Explicitly force LF for text source files.
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.cjs       text eol=lf
*.mjs       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.svg       text eol=lf
*.sh        text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore  text eol=lf

# Windows shell scripts must keep CRLF.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Treat lockfiles as generated for diff/review noise reduction.
package-lock.json   text eol=lf linguist-generated=true -diff

# Binary assets - never modify line endings or attempt textual diff.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.ico       binary
*.icns      binary
*.webp      binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.7z        binary
*.exe       binary
*.dll       binary
*.wasm      binary
*.vsix      binary
*.db        binary
*.covdb     binary

# Large binary assets tracked via Git LFS.
*.gif filter=lfs diff=lfs merge=lfs -text
